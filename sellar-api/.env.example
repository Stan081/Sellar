# Database
DATABASE_URL="postgresql://username:password@localhost:5432/sellar_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="77d"

# Payment Gateways
STRIPE_SECRET_KEY="sk-sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PAYSTACK_SECRET_KEY="sk-sk_test_..."
FLPAYSTACK_PUBLIC_KEY="pk-pk_pk_test_..."
FLUTTERWAVE_SECRET_KEY="FLWSE_TEST_..."
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST_..."

# App Configuration
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000,http://localhost:8081"

# File Upload (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel-blob-token-..."

# File Upload (Cloudinary/Supabase) - Alternative options
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email Service (SendGrid/SES)
SENDGRID_API_KEY="SG-sgSGSGSGSGSGSG.o"
SENDGRID_FROM_EMAIL="noreply@sellar.app"

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID="o-sid..."
TWILIO_AUTH_TOKEN="auth-token..."
TWILIO_PHONE_NUMBER="+1234567890"

# Redis (for caching/sessions)
REDIS_URL="redis://localhost:6379"

# Analytics
MIXPANEL_TOKEN="your-mixpanel-token"

# App URLs
APP_BASE_URL="http://localhost:3001"
FLUTTER_APP_URL_BASE_URL="http://localhost:8081"
