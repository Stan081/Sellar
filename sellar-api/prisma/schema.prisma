// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Vendor/User model for business owners
model Vendor {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String?  @unique
  password          String   // Hashed password
  businessName      String
  firstName         String
  lastName          String
  country           String
  currency          String   @default("USD")
  avatar            String?
  isEmailVerified   Boolean  @default(false)
  isPhoneVerified   Boolean  @default(false)
  preferredGateway  String   @default("stripe") // stripe, paystack, flutterwave
  theme             String   @default("light") // light, dark, system
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime?

  // Relations
  products          Product[]
  paymentLinks      PaymentLink[]
  transactions      Transaction[]
  customers         Customer[]
  socialConnections SocialConnection[]

  @@map("vendors")
}

// Social media OAuth connections
model SocialConnection {
  id              String         @id @default(cuid())
  vendorId        String
  platform        SocialPlatform
  accessToken     String         // Encrypted in production
  refreshToken    String?
  tokenExpiresAt  DateTime?
  platformUserId  String?        // e.g. Instagram user ID or FB Page ID
  platformUsername String?       // Display name / username
  pageId          String?        // Facebook Page ID (for page posting)
  pageName        String?        // Facebook Page name
  scopes          String[]       // Granted OAuth scopes
  isActive        Boolean        @default(true)
  connectedAt     DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vendor          Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, platform])
  @@map("social_connections")
}

// Product model
model Product {
  id          String    @id @default(cuid())
  vendorId    String
  name        String
  description String?
  category    String
  tags        String[]  // Array of tags
  price       Float
  quantity    Int?
  images      String[]  // Array of image URLs
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  links       PaymentLink[]

  @@map("products")
}

// Payment Link model
model PaymentLink {
  id          String          @id @default(cuid())
  vendorId    String
  productId   String?
  linkType    LinkType        @default(PUBLIC) // PUBLIC, PRIVATE
  amount      Float
  currency    String
  isReusable  Boolean         @default(false)
  isActive    Boolean         @default(true)
  expiresAt   DateTime?
  shortCode   String          @unique
  qrCode      String?
  metadata    Json?           // Additional link data
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  vendor      Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  linkViews   LinkView[]

  @@map("payment_links")
}

// Transaction model
model Transaction {
  id              String          @id @default(cuid())
  vendorId        String
  paymentLinkId   String
  customerId      String?
  amount          Float
  currency        String
  status          TransactionStatus @default(PENDING) // PENDING, COMPLETED, FAILED, CANCELLED
  gateway         String          // stripe, paystack, flutterwave
  gatewayTxId     String?         // External transaction ID
  customerEmail   String?
  customerPhone   String?
  metadata        Json?           // Additional transaction data
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?

  // Relations
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  paymentLink     PaymentLink     @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  customer        Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// Customer model (minimal data as per requirements)
model Customer {
  id            String   @id @default(cuid())
  vendorId      String
  email         String?
  phone         String?
  uniqueContact String   @unique // Email or phone for identification
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  // Relations
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@map("customers")
}

// Link tracking model
model LinkView {
  id            String   @id @default(cuid())
  paymentLinkId String
  ipAddress     String?
  userAgent     String?
  referrer      String?
  viewedAt      DateTime @default(now())

  // Relations
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)

  @@map("link_views")
}

// OTP verification model
model OTPVerification {
  id        String   @id @default(cuid())
  identifier String  // Email or phone
  code      String
  type      OTPType  @default(LOGIN) // LOGIN, REGISTRATION, PAYMENT
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@unique([identifier, type])
  @@map("otp_verifications")
}

// Enums
enum LinkType {
  PUBLIC
  PRIVATE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum OTPType {
  LOGIN
  REGISTRATION
  PAYMENT
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  TIKTOK
}
